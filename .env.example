# Configuración del Bot de Hidratación
# Copia este archivo a .env y completa los valores

# Token del bot de Telegram (obténlo de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Chat ID donde se enviarán los mensajes (obténlo de @userinfobot)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
